set shell := ["powershell.exe", "-c"]

# Shortcut for run
test:
    docker compose up -d postgres redis
    # Wait for postgres to be ready
    Write-Host "Waiting for postgres to be ready..."
    $containerId = (docker compose ps -q postgres) ; \
    if (-not $containerId) { Write-Error "Postgres container not found"; exit 1 } ; \
    $ready = $false ; \
    for ($i=0; $i -lt 30; $i++) { \
        $status = (docker exec $containerId pg_isready -U user) ; \
        if ($LASTEXITCODE -eq 0) { $ready = $true; break } \
        Start-Sleep -s 1; \
    } ; \
    if (-not $ready) { Write-Error "Postgres failed to become ready"; exit 1 } ; \
    $dbExists = (docker exec $containerId psql -U user -d postgres -tAc "SELECT 1 FROM pg_database WHERE datname='url_shortener_test'") ; \
    if ($dbExists -ne "1") { \
        Write-Host "Creating test database..."; \
        docker exec $containerId psql -U user -d postgres -c "CREATE DATABASE url_shortener_test"; \
    } ; \
    $env:DATABASE_URL="postgres://user:password@localhost:5432/url_shortener_test"; \
    $env:REDIS_URL="redis://localhost:6379/"; \
    cargo nextest run

# Run the application
run:
    docker compose up -d postgres redis
    $env:DATABASE_URL="postgres://user:password@localhost:5432/url_shortener"; \
    $env:REDIS_URL="redis://localhost:6379/"; \
    cargo run

# Nuke all docker resources for this project
nuke:
    docker compose down -v --remove-orphans

# Alias for nuke
nukeDocker: nuke
